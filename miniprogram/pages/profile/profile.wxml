<view class="container">
  <view class="user-card" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="name">{{userInfo.nickName}}</view>
  </view>
  <view class="login-area" wx:else>
    <button class="btn-login" bindtap="login">{{language === 'zh' ? '微信登录' : 'Login with WeChat'}}</button>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToResult">
      <text>{{language === 'zh' ? '我的报告' : 'My Report'}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAppointment">
      <text>{{language === 'zh' ? '预约采访' : 'Book Interview'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
