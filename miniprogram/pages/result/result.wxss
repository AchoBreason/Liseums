.container { padding: 32rpx; min-height: 100vh; }
.result-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 32rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.result-title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }
.result-content { font-size: 28rpx; color: #666; line-height: 1.8; }
.empty-state { padding: 80rpx 0; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; }
.actions { display: flex; flex-direction: column; gap: 24rpx; }
.btn-primary { background: linear-gradient(135deg, #FF6B6B, #FF8E8E); color: #fff; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; font-size: 32rpx; }
.btn-secondary { background: #f5f5f5; color: #666; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; font-size: 32rpx; }
