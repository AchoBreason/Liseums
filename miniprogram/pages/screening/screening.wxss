.container { min-height: 100vh; padding: 32rpx; box-sizing: border-box; }
.status-area { display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; }
.intro-title { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; text-align: center; }
.intro-desc { font-size: 28rpx; color: #666; margin-bottom: 48rpx; text-align: center; }
.price-tag { font-size: 48rpx; color: #FF6B6B; font-weight: bold; margin-bottom: 48rpx; }
.btn-primary { width: 400rpx; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #FF6B6B, #FF8E8E); color: #fff; border-radius: 44rpx; font-size: 32rpx; }
.loading-text { font-size: 28rpx; color: #999; }
.chat-area { display: flex; flex-direction: column; height: calc(100vh - 64rpx); }
.message-list { flex: 1; padding: 24rpx; }
.message-item { margin-bottom: 24rpx; }
.msg-bubble { max-width: 80%; padding: 24rpx 28rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.6; }
.msg-bubble.assistant { background: #f5f5f5; color: #333; margin-right: auto; }
.msg-bubble.user { background: #FF6B6B; color: #fff; margin-left: auto; }
.loading-msg { font-size: 26rpx; color: #999; padding: 16rpx; }
.input-area { padding: 24rpx; background: #fff; border-top: 1rpx solid #eee; }
.question-hint { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.input-row { display: flex; align-items: center; gap: 16rpx; }
.answer-input { flex: 1; height: 72rpx; padding: 0 24rpx; background: #f5f5f5; border-radius: 36rpx; font-size: 28rpx; }
.btn-send { width: 120rpx; height: 72rpx; line-height: 72rpx; background: #FF6B6B; color: #fff; border-radius: 36rpx; font-size: 28rpx; }
.completed-area { padding: 48rpx; text-align: center; }
.done-title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 48rpx; }
.btn-primary { width: 400rpx; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #FF6B6B, #FF8E8E); color: #fff; border-radius: 44rpx; font-size: 32rpx; margin: 0 auto; }
