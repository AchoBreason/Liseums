.container { padding: 32rpx; }
.form-group { margin-bottom: 32rpx; }
.label { display: block; font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.picker { padding: 24rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; }
.textarea { width: 100%; min-height: 160rpx; padding: 24rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }
.btn-primary { margin-top: 48rpx; background: linear-gradient(135deg, #FF6B6B, #FF8E8E); color: #fff; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; font-size: 32rpx; }
