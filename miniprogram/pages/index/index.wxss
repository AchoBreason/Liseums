.container { padding: 0 0 40rpx; }
.banner-swiper { height: 360rpx; margin-bottom: 32rpx; }
.banner-img { width: 100%; height: 100%; }
.banner-title { position: absolute; bottom: 24rpx; left: 32rpx; color: #fff; font-size: 36rpx; font-weight: bold; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5); }
.section-title { font-size: 32rpx; font-weight: bold; margin: 24rpx 32rpx 16rpx; color: #333; }
.feature-list { margin: 0 24rpx; background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.feature-item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.feature-item:last-child { border-bottom: none; }
.feature-icon { width: 80rpx; height: 80rpx; margin-right: 24rpx; }
.feature-content { flex: 1; }
.feature-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.feature-desc { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }
.feature-price { font-size: 28rpx; color: #FF6B6B; font-weight: 600; display: block; margin-top: 8rpx; }
.feature-arrow { font-size: 40rpx; color: #ccc; }
.case-list { margin: 0 24rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); }
.case-item { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.case-item:last-child { border-bottom: none; }
.case-name { font-size: 28rpx; font-weight: 600; color: #333; }
.case-highlight { font-size: 26rpx; color: #666; margin-top: 8rpx; }
.case-time { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.lang-switch { text-align: center; margin-top: 40rpx; font-size: 26rpx; color: #999; }
